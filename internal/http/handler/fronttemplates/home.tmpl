{{define "home_page"}}
{{template "site_header" .}}
<section class="hero">
  <div class="wrap hero-grid">
    <div class="hero-panel">
      <h1><span>{{.HeroTitle}}</span></h1>
      <p>{{.HeroSubtitle}}</p>
    </div>
  </div>
</section>
<main class="wrap page-grid">
  <section class="content-area">
    <div class="feed glass">
      <div class="section-head" id="content-stream">
        <strong>最新文章</strong>
      </div>
    {{if .Articles}}
      {{range .Articles}}
      <article class="article-card post">
        <div class="article-meta">
          <span>{{formatUnix .CTime}}</span>
          <span>作者：{{.Author}}</span>
          <a href="{{.CategoryHref}}">分类：{{.CategoryName}}</a>
        </div>
        <h2><a href="{{.Link}}">{{.Title}}</a></h2>
        <p class="description">{{.Description}}</p>
        <p class="preview">{{.ContentPreview}}</p>
        <div class="article-footer">
          <div class="tags">
            {{range .Tags}}<span class="tag">{{.}}</span>{{end}}
          </div>
          <a class="read-more" href="{{.Link}}">阅读全文</a>
        </div>
      </article>
      {{end}}
    {{else}}
      <div class="empty-state">暂无文章内容</div>
    {{end}}
    </div>
    <nav class="pager glass" aria-label="分页导航">
      <div class="pager-info">{{.Pagination.Page}} / {{.Pagination.TotalPages}} · {{.Pagination.Total}} posts</div>
      <div class="pager-main">
        {{if .Pagination.HasPrev}}
        <a class="pager-btn" href="/?page={{.Pagination.PrevPage}}" aria-label="上一页">上一页</a>
        {{else}}
        <span class="pager-btn disabled">上一页</span>
        {{end}}
        <div class="pager-pages">
          {{range .Pagination.Items}}
            {{if .IsEllipsis}}
            <span class="page ellipsis">...</span>
            {{else if .Active}}
            <span class="page active">{{.Label}}</span>
            {{else}}
            <a class="page" href="/?page={{.Page}}">{{.Label}}</a>
            {{end}}
          {{end}}
        </div>
        {{if .Pagination.HasNext}}
        <a class="pager-btn" href="/?page={{.Pagination.NextPage}}" aria-label="下一页">下一页</a>
        {{else}}
        <span class="pager-btn disabled">下一页</span>
        {{end}}
      </div>
    </nav>
  </section>
  {{template "sidebar" .}}
</main>
{{template "site_footer" .}}
{{end}}
