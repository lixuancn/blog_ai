{{define "site_header"}}
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{.SEO.Title}}</title>
  <meta name="description" content="{{.SEO.Description}}">
  <meta name="keywords" content="{{.SEO.Keywords}}">
  <link rel="stylesheet" href="/assets/front.css">
</head>
<body class="front-body">
  <header class="topbar">
    <div class="wrap topbar-inner">
      <a class="brand" href="/" aria-label="{{.Site.Title}}">
        <span class="brand-mark" aria-hidden="true">
          <span class="brand-letter">L</span>
        </span>
        <span class="brand-copy">
          <strong>{{.Site.Title}}</strong>
        </span>
      </a>
      <button class="menu-btn" type="button" aria-label="切换导航" data-nav-toggle>菜单</button>
      <nav class="nav" data-nav-panel>
          {{range .Navigation}}
          <div class="nav-item{{if .Children}} has-children{{end}}">
            <a href="{{.Href}}" {{if .External}}target="_blank" rel="noopener noreferrer"{{end}}>{{.Name}}</a>
            {{if .Children}}
            <div class="nav-sub">
              {{range .Children}}
              <a href="{{.Href}}" {{if .External}}target="_blank" rel="noopener noreferrer"{{end}}>
                <span>{{.Name}}</span>
                <span class="nav-pill">Sub</span>
              </a>
              {{end}}
            </div>
            {{end}}
          </div>
          {{end}}
      </nav>
    </div>
  </header>
{{end}}

{{define "site_footer"}}
  <footer class="site-footer">
    <div class="wrap">
      <p><a href="https://beian.miit.gov.cn/" target="_blank" rel="noopener noreferrer">京ICP备14005030号</a></p>
    </div>
  </footer>
  <script src="/assets/front.js"></script>
</body>
</html>
{{end}}

{{define "sidebar"}}
<aside class="sidebar glass" id="recommend-stream">
  <div class="section-head">
    <strong>推荐内容</strong>
  </div>
  {{if .Recommendations}}
  <ul class="recommend-list">
    {{range .Recommendations}}
    <li>
      <a class="recommend-link" href="{{.Link}}">
        <strong>{{.Title}}</strong>
      </a>
    </li>
    {{end}}
  </ul>
  {{else}}
  <div class="empty-state">暂无推荐内容</div>
  {{end}}
</aside>
{{end}}
